# Copy to `.env` for local Docker / dev.
# Values in env_file are passed literally (including `$` characters).
# Compose may warn about `$VAR` in .env when parsing the compose file — safe to ignore for env_file keys.

# Required
DJANGO_SECRET_KEY=change-me
ENVIRONMENT=development

# Docker Compose sets REDIS_HOST=redis for the api service; override for bare-metal dev if needed.
REDIS_HOST=redis
REDIS_PORT=6379

# Email (auth OTP, contest reminders)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Frontend URL (contest reminder emails, links)
FRONTEND_URL=http://localhost:3000

# AI features
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Optional — phone OTP (authentication)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PASSCODE=
TWILIO_VERIFICATION_NUMBER=
TWILIO_VERIFICATION_NUMBER_SID=

# Optional — S3 presigned uploads (api/v1/core/create-presigned-url/)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_BUCKET_URL=

# Optional
NOTIFICATION_EMAIL=

# Production only (see prod.env) — used when ENVIRONMENT=production
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=
